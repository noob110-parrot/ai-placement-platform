# Production Environment Variables
# Used by Railway, Vercel, and other deployment platforms

# ── Database (Auto-generated by Railway) ──
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:password@postgres:5432/placement_db
REDIS_URL=redis://redis:6379

# ── Backend Security ──
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── AI / LLM ──
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── WhatsApp Business API ──
WHATSAPP_API_TOKEN=your-whatsapp-api-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# ── Google OAuth & Calendar ──
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-frontend-domain/api/auth/callback/google
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar

# ── n8n Automation ──
N8N_WEBHOOK_URL=https://your-n8n-railway-url
N8N_API_KEY=your-n8n-api-key
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=placement123
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=https

# ── Email (Gmail SMTP) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-placement-cell@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=AI Placement Platform <placement@university.edu>

# ── Frontend (Vercel) ──
NEXT_PUBLIC_API_URL=https://your-backend-railway-url
NEXT_PUBLIC_APP_NAME=AI Placement Platform
NEXT_PUBLIC_UNIVERSITY_NAME=Your University

# ── CORS ──
# Include your Vercel frontend URL
ALLOWED_ORIGINS=["https://frontend-one-pi-39.vercel.app","https://your-custom-domain.com"]

# ── Feature Flags ──
ENABLE_WHATSAPP_NOTIFICATIONS=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_CALENDAR_SYNC=true
ENABLE_AI_SUMMARIZER=true

# ── PgAdmin ──
PGADMIN_DEFAULT_EMAIL=admin@placement.edu
PGADMIN_DEFAULT_PASSWORD=admin
