# ─────────────────────────────────────────────
# AI Placement Platform — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@postgres:5432/placement_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=placement_db

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Backend Security ──────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── AI / LLM ──────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── WhatsApp Business API (Meta) ──────────────
WHATSAPP_API_TOKEN=your-whatsapp-api-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# ── Google OAuth & Calendar ───────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar

# ── n8n Automation ────────────────────────────
N8N_WEBHOOK_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=placement123

# ── Email (Gmail SMTP) ────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-placement-cell@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=AI Placement Platform <placement@university.edu>

# ── Frontend (Next.js) ────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=AI Placement Platform
NEXT_PUBLIC_UNIVERSITY_NAME=Your University

# ── CORS ──────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001","http://0.0.0.0:3000","http://0.0.0.0:3001"]

# ── Feature Flags ─────────────────────────────
ENABLE_WHATSAPP_NOTIFICATIONS=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_CALENDAR_SYNC=true
ENABLE_AI_SUMMARIZER=true

# ── ngrok Setup (for sharing with judges) ─────
# To use ngrok tunnels:
# 1. Sign up at: https://dashboard.ngrok.com/signup
# 2. Get your authtoken: https://dashboard.ngrok.com/get-started/your-authtoken
# 3. Export: export NGROK_AUTHTOKEN='your-authtoken-here'
# 4. Run: ./scripts/setup-ngrok.sh
NGROK_AUTHTOKEN=your-ngrok-authtoken-here
